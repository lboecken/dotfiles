#!/bin/bash

if [[ -z "$1" ]]; then
    echo "Package name required"
    exit 2
fi

PYTHON_VER="${2:-3.13}"

package_path=$(uv run --with "$1" --python "${2:-3.13}" python -c "
import $1
import pathlib
print(str(pathlib.Path($1.__file__).parent))
")

$HOME/.local/nvim/bin/nvim --cmd "cd $package_path" $package_path

